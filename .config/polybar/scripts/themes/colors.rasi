* {
  bg:       #000000;  // Fondo negro
  fg:       #ffffff;  // Texto blanco
  bg-alt:   #111111;  // Alternativa de fondo más clara (opcional)
  selected: #222222;  // Fondo para elemento seleccionado
  urgent:   #ff0000;  // Rojo para urgente (si lo usas)
  border:   #333333;  // Gris para bordes (suave)
}

